-- M2 flagship demo: REST API powered by AI primitives.
-- ~25 lines for what Python+FastAPI+Anthropic SDK takes ~80.
--
-- Run:  python main.py examples/ai_api.feel
-- Then: curl http://localhost:3000/summarize -X POST -d '{"text": "..."}'
--       curl http://localhost:3000/classify -X POST -d '{"text": "bug found"}'
--       curl "http://localhost:3000/ask?q=what+is+feel"
--
-- Default provider is 'mock' (no API key). Set ANTHROPIC_API_KEY for real Claude.

route GET "/" -> respond map {
  service: "Feel AI demo",
  endpoints: ["/ask", "/summarize", "/classify", "/chat"],
  provider: ai.provider(),
}

-- GET /ask?q=...
route GET "/ask" -> do {
  let q = query.q
  when q == nothing -> respond 400 map { error: "missing ?q=" } otherwise -> respond map { question: q, answer: ai.ask(q) }
}

-- POST /summarize { text }
route POST "/summarize" -> do {
  let text = body.text
  when text == nothing -> respond 400 map { error: "missing 'text' in body" } otherwise -> respond map { original_length: length(text), summary: ai.summarize(text) }
}

-- POST /classify { text }
route POST "/classify" -> do {
  let text = body.text
  let categories = ["bug", "feature", "question", "other"]
  when text == nothing -> respond 400 map { error: "missing 'text' in body" } otherwise -> respond map { text: text, label: ai.classify(text, categories) }
}

-- POST /chat { messages: [{ role, content }, ...] }
route POST "/chat" -> do {
  let msgs = body.messages
  when msgs == nothing -> respond 400 map { error: "missing 'messages' list" } otherwise -> respond map { reply: ai.chat(msgs) }
}

serve on 3000
